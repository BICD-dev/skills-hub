# ─── SERVER ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── KORAPAY ───────────────────────────────────────────────────────────────────
KORAPAY_API_BASE_URL=https://api.korapay.com
KORAPAY_SECRET_KEY=
KORAPAY_PUBLIC_KEY=
KORAPAY_REDIRECT_URL=https://yourdomain.com/redirect
KORAPAY_WEBHOOK_URL=https://yourdomain.com/api/webhook/payment

# ─── EMAIL ─────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=true

# Provider: "brevo" (recommended for Render) or "smtp" (generic SMTP e.g. Gmail)
EMAIL_PROVIDER=brevo

EMAIL_FROM_NAME=Lead Conference
EMAIL_FROM_ADDRESS=skills1hub@gmail.com

# Brevo — used when EMAIL_PROVIDER=brevo
# SMTP login: your Brevo account email
# API key: the SMTP key generated in Brevo > SMTP & API > SMTP
BREVO_SMTP_USER=
BREVO_API_KEY=
# Generic SMTP — used when EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# ─── EMAIL TEMPLATE URLS ───────────────────────────────────────────────────────
EMAIL_ATTENDANCE_GROUP_URL=https://chat.whatsapp.com/your-attendance-group
EMAIL_SKILLS_HUB_GROUP_URL=https://chat.whatsapp.com/your-skills-hub-group
